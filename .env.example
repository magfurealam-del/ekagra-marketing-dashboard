# Site access gate. Users enter this password on the lock screen.
SITE_PASSWORD=replace-with-a-strong-dashboard-password

# Optional separate signing secret for the httpOnly auth cookie.
# If omitted, SITE_PASSWORD is used as the signing secret.
SITE_AUTH_SECRET=replace-with-a-long-random-secret

# Server-only Meta credentials. These are never sent to the browser.
META_ADS_ACCESS_TOKEN=replace-with-long-lived-meta-ads-token
META_AD_ACCOUNT_ID=700609876173906

# Optional: enables the Page Insights tab.
META_PAGE_ID=EkagraHealthBD
META_PAGE_ACCESS_TOKEN=replace-with-page-token
